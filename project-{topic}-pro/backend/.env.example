```
PORT=5000
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=ml_user
DB_PASSWORD=ml_password
DB_NAME=ml_toolbox_db

# JWT Configuration
