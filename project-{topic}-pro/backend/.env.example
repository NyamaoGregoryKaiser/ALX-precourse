```
# Application
NODE_ENV=development
PORT=5000
APP_NAME="CMS Project"

# Database
DB_CLIENT=pg
DB_HOST=localhost
DB_PORT=5432
DB_USER=cms_user
DB_PASSWORD=cms_password
DB_NAME=cms_db

# JWT Secret (generate a strong one: openssl rand -base64 32)
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRES_IN=1h

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Logging
LOG_LEVEL=info
```