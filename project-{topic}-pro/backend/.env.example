# Application Configuration
APP_PORT=9080
APP_THREADS=4

# Database Configuration (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/cms_db"

# JWT Configuration
JWT_SECRET="your_very_secure_and_long_jwt_secret_key_alx_project"
JWT_EXPIRATION_HOURS=24 # Token expiration in hours

# Logging Configuration
LOG_LEVEL=info # trace, debug, info, warn, error, critical, off

# Caching Configuration
CACHE_TTL_SECONDS=300 # Time-to-live for cached items in seconds (5 minutes)

# Rate Limiting Configuration
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_TIME_WINDOW_MINUTES=1