```
# Application (for testing)
NODE_ENV=test
PORT=5001 # Use a different port for tests
SECRET_KEY=test_secret
REFRESH_SECRET_KEY=test_refresh_secret
ACCESS_TOKEN_EXPIRATION=10m
REFRESH_TOKEN_EXPIRATION=1d
RATE_LIMIT_WINDOW_MS=1000 # 1 second
RATE_LIMIT_MAX_REQUESTS=5

# Database (for testing)
DB_HOST=localhost
DB_PORT=5433 # Use a different port
DB_USERNAME=test_user
DB_PASSWORD=test_password
DB_DATABASE=test_db

# Redis (for testing)
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=test_redis_password

# Logging
LOG_LEVEL=error # Keep test logs minimal
```