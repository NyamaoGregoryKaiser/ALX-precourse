{
  "name": "task-management-backend",
  "version": "1.0.0",
  "description": "Backend for a Task Management System",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "nodemon --exec ts-node src/server.ts",
    "build": "tsc",
    "typeorm": "typeorm-ts-node-commonjs",
    "migration:create": "typeorm-ts-node-commonjs migration:create ./src/migrations/$npm_config_name",
    "migration:run": "typeorm-ts-node-commonjs migration:run -d ./src/config/database.ts",
    "migration:revert": "typeorm-ts-node-commonjs migration:revert -d ./src/config/database.ts",
    "seed": "ts-node src/seeders/seed.ts",
    "test": "jest --detectOpenHandles --coverage",
    "test:watch": "jest --watch --detectOpenHandles"
  },
  "keywords": [],
  "author": "ALX Software Engineering Team",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.2",
    "cache-manager": "^5.3.2",
    "cache-manager-redis-yet": "^5.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "http-status-codes": "^2.3.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pg": "^8.12.0",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.20",
    "winston": "^3.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.14.8",
    "@types/supertest": "^6.0.2",
    "@types/validator": "^13.11.10",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.2"
  }
}