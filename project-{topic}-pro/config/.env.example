```
# Application Configuration
SERVER_PORT=8080
AGENT_INTERVAL_SECONDS=10 # How often the monitoring agent collects data

# Database Configuration
DATABASE_URL="postgresql://aurora_user:aurora_password@localhost:5432/aurora_metrics_db"

# JWT Configuration
JWT_SECRET="YOUR_SUPER_SECRET_JWT_KEY_HERE_MIN_32_CHARS" # IMPORTANT: Change this in production!
JWT_EXPIRY_SECONDS=3600 # Token expiry in seconds (1 hour)

# Caching Configuration
CACHE_TTL_SECONDS=300 # Time-to-live for cached items in seconds (5 minutes)

# Rate Limiting Configuration
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60 # 100 requests per minute per IP/user

# Logging Configuration
LOG_LEVEL=info # debug, info, warn, error, critical
```