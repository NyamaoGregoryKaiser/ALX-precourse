# --- Application Settings ---
APP_NAME="Task Management Backend"
DEBUG=true
ENVIRONMENT="development"
HOST="0.0.0.0"
PORT=8000

# --- Database Settings ---
DATABASE_URL="postgresql+psycopg2://user:password@db:5432/task_db"
# Example for local development without Docker:
# DATABASE_URL="postgresql+psycopg2://user:password@localhost:5432/task_db"

# --- JWT Settings ---
SECRET_KEY="YOUR_SUPER_SECRET_KEY_CHANGE_THIS_IN_PRODUCTION"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080 # 7 days

# --- Redis Settings (for Caching and Rate Limiting) ---
REDIS_URL="redis://redis:6379/0"
# Example for local development without Docker:
# REDIS_URL="redis://localhost:6379/0"

# --- Logging Settings ---
LOG_LEVEL="INFO" # DEBUG, INFO, WARNING, ERROR, CRITICAL
