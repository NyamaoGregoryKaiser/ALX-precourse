```ini
# Core Application
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# Database Configuration (PostgreSQL)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=admin
DATABASE_PASSWORD=password
DATABASE_NAME=task_manager_db

# JWT Configuration
JWT_SECRET=super-secret-jwt-key-replace-with-strong-one
JWT_EXPIRES_IN=1h

# Throttler (Rate Limiting)
THROTTLER_TTL=60 # seconds
THROTTLER_LIMIT=100 # requests per TTL

# Redis Cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD= # Leave empty if no password
REDIS_CACHE_TTL=3600 # default TTL in seconds (1 hour)
```