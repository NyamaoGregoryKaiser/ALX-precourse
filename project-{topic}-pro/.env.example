# Application
PORT=5000
NODE_ENV=development # or production, test

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=alxpay
DB_SSL=false # Set to true if connecting to a cloud DB requiring SSL

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_key_that_is_at_least_32_characters_long
JWT_EXPIRES_IN=1d
REFRESH_TOKEN_SECRET=another_super_secret_key_for_refresh_tokens

# Hashing
HASH_SALT_ROUNDS=10

# Redis Cache & Rate Limiting
REDIS_URL=redis://localhost:6379

# External Payment Gateway (Mock)
PAYMENT_GATEWAY_URL=http://localhost:5000/api/mock-gateway # This would be a real gateway URL

# Webhook Secret (for signing outbound webhooks)
WEBHOOK_SECRET=your_webhook_signing_secret

# Other settings
MAX_PAYMENT_AMOUNT=100000 # Example max payment in USD
FRONTEND_URL=http://localhost:3000