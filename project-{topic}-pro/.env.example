```
# --- Core Application Settings ---
FLASK_APP=wsgi.py
FLASK_ENV=development # production, testing
SECRET_KEY="super-secret-jwt-key-please-change-in-production"
APP_SETTINGS_MODULE="config.DevelopmentConfig" # config.ProductionConfig, config.TestingConfig
DEBUG=True

# --- Database Settings ---
DATABASE_URL="postgresql://user:password@db:5432/cms_db"

# --- JWT Settings ---
JWT_SECRET_KEY="another-super-secret-jwt-key-change-this-too"
JWT_ACCESS_TOKEN_EXPIRES_SECONDS=3600 # 1 hour
JWT_REFRESH_TOKEN_EXPIRES_DAYS=30 # 30 days

# --- Caching Settings ---
CACHE_REDIS_URL="redis://redis:6379/0"
CACHE_DEFAULT_TIMEOUT=300 # 5 minutes

# --- Rate Limiting Settings ---
RATELIMIT_ENABLED=True
RATELIMIT_STORAGE_URL="redis://redis:6379/1" # Different DB for rate limiting
RATELIMIT_DEFAULT_LIMIT="50 per minute" # Default rate limit for all endpoints

# --- Logging Settings ---
LOG_LEVEL=INFO # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FILE_PATH="/var/log/cms_app/app.log" # For Docker, outside volume
```