    Browser -- API Calls (HTTP/HTTPS) --> Nginx
    Nginx -- Proxy API --> Backend(Backend API - NestJS)

    Backend -- Reads/Writes --> PostgreSQL(PostgreSQL Database)
    Backend -- Reads/Writes --> Redis(Redis Cache)

