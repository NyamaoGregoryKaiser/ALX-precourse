{
  "name": "payment-system",
  "version": "1.0.0",
  "description": "A comprehensive, production-ready payment processing system.",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "NODE_ENV=development nodemon src/server.js",
    "test": "NODE_ENV=test jest --detectOpenHandles --forceExit",
    "test:unit": "NODE_ENV=test jest --detectOpenHandles --forceExit src/tests/unit",
    "test:integration": "NODE_ENV=test jest --detectOpenHandles --forceExit src/tests/integration",
    "test:coverage": "NODE_ENV=test jest --coverage --detectOpenHandles --forceExit",
    "migrate:make": "knex migrate:make --knexfile database/knexfile.js",
    "migrate:latest": "knex migrate:latest --knexfile database/knexfile.js",
    "migrate:rollback": "knex migrate:rollback --knexfile database/knexfile.js",
    "seed:make": "knex seed:make --knexfile database/knexfile.js",
    "seed:run": "knex seed:run --knexfile database/knexfile.js",
    "lint": "eslint src/**/*.js",
    "prettify": "prettier --write src/**/*.js"
  },
  "keywords": [],
  "author": "ALX Software Engineering Student",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "joi": "^17.12.3",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "objection": "^3.1.4",
    "pg": "^8.11.5",
    "uuid": "^9.0.1",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "prettier": "^3.2.5",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFilesAfterEnv": [
      "./jest.setup.js"
    ],
    "collectCoverage": true,
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "json",
      "lcov",
      "text",
      "clover"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/app.js",
      "!src/server.js",
      "!src/routes/index.js",
      "!src/config/*.js",
      "!src/utils/db.js",
      "!src/tests/**/*.js",
      "!src/api/*.js"
    ]
  }
}