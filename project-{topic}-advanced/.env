```
# .env - Environment variables for VisGenius
# This file should NOT be committed to version control in production!

# Core Application Settings
APP_PORT=8080
LOG_LEVEL=DEBUG # INFO, WARN, ERROR, FATAL
DATABASE_PATH=visgenius.db # Path to SQLite database file

# Security Settings
JWT_SECRET=super_secret_jwt_key_that_should_be_long_and_random_but_unique_to_this_env
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# Caching Settings
DATA_CACHE_TTL_MINUTES=30
CHART_CACHE_TTL_MINUTES=10

# Rate Limiting Settings
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
```