```
# Database Configuration
DB_HOST=db
DB_PORT=5432
DB_USER=product_user
DB_PASSWORD=product_password
DB_NAME=product_catalog_db
DB_DIALECT=postgres

# Server Configuration
PORT=5000
FRONTEND_URL=http://localhost:3000

# JWT Configuration
JWT_SECRET=supersecretjwtkeythatshouldbeverylongandrandominproduction
JWT_EXPIRES_IN=1h

# Admin User Credentials (for seeding)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=adminpassword

# Caching Configuration
CACHE_TTL_SECONDS=300 # Time to live for cache entries (5 minutes)

# Logging
LOG_LEVEL=info # error, warn, info, http, verbose, debug, silly
```