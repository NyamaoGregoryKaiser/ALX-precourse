# Flask Application
FLASK_APP=wsgi.py
FLASK_ENV=development
SECRET_KEY=your_flask_app_secret_key_here
APP_BASE_URL=http://localhost:5000

# Database
DATABASE_URL=postgresql://user:password@db:5432/auth_db
TEST_DATABASE_URL=postgresql://test_user:test_password@db_test:5432/test_auth_db # For testing environment

# JWT
JWT_SECRET_KEY=your_jwt_secret_key_here

# Mail Server (Example: Mailtrap for development)
MAIL_SERVER=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USE_TLS=true
MAIL_USERNAME=your_mailtrap_username
MAIL_PASSWORD=your_mailtrap_password
MAIL_DEFAULT_SENDER=noreply@authsystem.com

# Redis Cache & Rate Limiting
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
RATELIMIT_STORAGE_URL=redis://redis:6379/1