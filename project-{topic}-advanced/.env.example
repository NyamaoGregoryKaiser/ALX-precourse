```dotenv
# Application
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# Database (PostgreSQL)
DB_HOST=db
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=password
DB_NAME=datavizdb
DB_SYNCHRONIZE=false # Set to false in production. Use TypeORM migrations.
DB_LOGGING=false    # Set to true for debugging SQL queries

# JWT
JWT_SECRET=your_strong_jwt_secret_key_here
JWT_EXPIRES_IN=1d

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000   # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100   # 100 requests per 15 minutes

# Caching (In-memory cache for now. For production, consider Redis.)
CACHE_TTL_SECONDS=300         # 5 minutes
```