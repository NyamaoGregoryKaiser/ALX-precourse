# Flask Application Configuration
FLASK_APP=manage.py
FLASK_ENV=development # Options: development, testing, production
SECRET_KEY=supersecretkey_replace_this_in_production!
FLASK_DEBUG=1 # Set to 0 in production

# Database Configuration (DBOptiFlow's own database)
DATABASE_URL=postgresql://dboptiflow_user:dboptiflow_password@dboptiflow_db:5432/dboptiflow_db

# Redis Configuration (for Celery broker/backend and caching)
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# JWT Configuration
JWT_SECRET_KEY=jwt_super_secret_key_replace_this_in_production!
JWT_ACCESS_TOKEN_EXPIRES_SECONDS=3600 # 1 hour

# Caching Configuration
CACHE_TYPE=RedisCache # Options: RedisCache, SimpleCache
CACHE_DEFAULT_TIMEOUT=300 # 5 minutes

# Logging Configuration
LOG_LEVEL=INFO # Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# External DB credentials for testing purposes if you want to connect to a local postgres/mysql
# EXTERNAL_DB_HOST=localhost
# EXTERNAL_DB_PORT=5432
# EXTERNAL_DB_USER=testuser
# EXTERNAL_DB_PASS=testpass
# EXTERNAL_DB_NAME=testdb
# EXTERNAL_DB_TYPE=postgresql
```