```ini
# Application Port
APP_PORT=18080

# Database Configuration
DATABASE_PATH=db/alx_project_management.db

# Logging Configuration (0=DEBUG, 1=INFO, 2=WARNING, 3=ERROR, 4=CRITICAL)
LOG_LEVEL=0

# JWT Authentication
JWT_SECRET=super_secret_jwt_key_please_change_this_in_production_seriously
JWT_EXPIRY_MINUTES=60

# Rate Limiting (per IP address)
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=100
```