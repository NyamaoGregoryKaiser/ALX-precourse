```dotenv
# General Application Settings
NODE_ENV=development # development, test, production
PORT=5000 # Backend API port
FRONTEND_PORT=3000 # Frontend serving port
FRONTEND_URL=http://localhost:3000 # Frontend URL for CORS settings

# Database (PostgreSQL) Settings
DB_HOST=localhost # Use 'postgres' if running in Docker Compose
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=task_management_db

# JWT Authentication Settings
JWT_SECRET=supersecretjwtkeythatshouldbeverylongandrandominproductionandnotcommitted
JWT_EXPIRES_IN=1h # E.g., '1h', '7d', '24h'

# Redis Cache Settings
REDIS_HOST=localhost # Use 'redis' if running in Docker Compose
REDIS_PORT=6379

# API Rate Limiting Settings
RATE_LIMIT_WINDOW_MS=60000 # Time window in milliseconds (e.g., 60000ms = 1 minute)
RATE_LIMIT_MAX_REQUESTS=100 # Maximum requests per IP per window

# Frontend specific variables (prefix with VITE_ for Vite to expose them to client-side)
# VITE_API_BASE_URL should be the full backend URL for local development
# For Docker Compose with Nginx, this will be set to /api/v1 (relative path)
VITE_API_BASE_URL=http://localhost:5000/api/v1
```