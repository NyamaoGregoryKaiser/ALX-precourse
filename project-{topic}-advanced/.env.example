```
# .env.example
# Rename this file to .env and fill in your actual values.

# Application Port
APP_PORT=18080

# Database Path
DATABASE_PATH=./data/mobile_backend.db

# JWT Secret Key (MUST be strong and kept secret in production)
JWT_SECRET="your_very_secret_jwt_key_that_is_at_least_32_characters_long_and_random"

# Cache TTL in seconds (e.g., 600 for 10 minutes)
CACHE_TTL_SECONDS=600

# Rate Limiter settings
# Max requests per window
RATE_LIMIT_MAX_REQUESTS=100
# Time window in seconds
RATE_LIMIT_WINDOW_SECONDS=60
```