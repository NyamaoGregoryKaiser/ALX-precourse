```
NODE_ENV=development
PORT=5000

DATABASE_URL="postgresql://user:password@localhost:5432/taskdb?schema=public"
# For Docker: DATABASE_URL="postgresql://user:password@db:5432/taskdb?schema=public"
# For Testing: DATABASE_URL_TEST="postgresql://test_user:test_password@localhost:5433/taskdb_test?schema=public"

JWT_SECRET="YOUR_SUPER_SECRET_JWT_KEY_HERE_CHANGE_ME"
JWT_EXPIRATION_TIME="1h"

REFRESH_TOKEN_SECRET="YOUR_SUPER_SECRET_REFRESH_KEY_HERE_CHANGE_ME"
REFRESH_TOKEN_EXPIRATION_TIME="7d"

REDIS_URL="redis://localhost:6379"
# For Docker: REDIS_URL="redis://redis:6379"

LOG_LEVEL=info
```

