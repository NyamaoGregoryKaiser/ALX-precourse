              "raw": "{\n    \"name\": \"My First Dashboard\",\n    \"description\": \"A dashboard with key metrics.\",\n    \"chartIds\": [\"{{chartId1}}\", \"{{chartId2}}\"],\n    \"layout\": [\n        {\"i\": \"{{chartId1}}\", \"x\": 0, \"y\": 0, \"w\": 6, \"h\": 8},\n        {\"i\": \"{{chartId2}}\", \"x\": 6, \"y\": 0, \"w\": 6, \"h\": 8}\n    ]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
