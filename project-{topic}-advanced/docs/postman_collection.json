                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Sales by Month\",\n    \"type\": \"BAR\",\n    \"dataSourceId\": \"{{dataSourceId}}\",\n    \"query\": \"SELECT month, sales FROM sales_data ORDER BY month\",\n    \"configuration\": \"{\\\"title\\\":{\\\"text\\\":\\\"Monthly Sales\\\"},\\\"tooltip\\\":{},\\\"legend\\\":{\\\"data\\\":[\\\"Sales\\\"]}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/charts",
              "host": ["{{baseUrl}}"],
              "path": ["charts"]
