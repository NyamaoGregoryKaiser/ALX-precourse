      "key": "authToken",
      "value": ""
    },
    {
      "key": "dataSourceId",
      "value": ""
    },
    {
      "key": "chartId1",
      "value": ""
    },
    {
      "key": "chartId2",
      "value": ""
    },
    {
      "key": "dashboardId",
      "value": ""
    }
  ]
