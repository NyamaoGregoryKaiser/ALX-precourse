  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Example Pre-request Script: Set base URL from environment",
          "pm.environment.set(\"baseUrl\", \"http://localhost:5000/api/v1\");",
          "",
          "// Example: Automatically extract JWT from login response",
          "if (pm.request.url.includes('/auth/login') && pm.response && pm.response.headers.has('x-auth-token')) {",
          "    pm.environment.set(\"authToken\", pm.response.headers.get('x-auth-token'));",
          "    console.log('JWT Token set:', pm.environment.get('authToken'));",
          "}",
          "",
          "// Example: Capture IDs for chaining requests (requires running requests in order)",
          "if (pm.request.url.includes('/auth/register') && pm.response && pm.response.json().userId) {",
          "    pm.environment.set(\"registeredUserId\", pm.response.json().userId);",
          "}",
          "if (pm.request.url.includes('/data-sources') && pm.request.method === 'POST' && pm.response && pm.response.json().id) {",
          "    pm.environment.set(\"dataSourceId\", pm.response.json().id);",
          "}",
          "if (pm.request.url.includes('/charts') && pm.request.method === 'POST' && pm.response && pm.response.json().id) {",
          "    pm.environment.set(\"chartId1\", pm.response.json().id); // If you create multiple, you need to set more env vars",
          "}"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000/api/v1"
