```
NODE_ENV=development
PORT=5000

# JWT Settings
JWT_SECRET=your_jwt_secret_key_here_make_it_strong_and_long
JWT_ACCESS_EXPIRATION_MINUTES=30
JWT_REFRESH_EXPIRATION_DAYS=7
JWT_RESET_PASSWORD_EXPIRATION_MINUTES=10
JWT_VERIFY_EMAIL_EXPIRATION_MINUTES=10

# Database Settings (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=user
DB_PASSWORD=password
DB_NAME=auth_db
# Optional: Database connection pool settings
# DB_POOL_MAX=10
# DB_POOL_MIN=2
# DB_IDLE_TIMEOUT_MILLIS=30000

# Redis Settings (for Rate Limiting and potentially Caching)
REDIS_URL=redis://localhost:6379
REDIS_DB=0 # Redis database index (0-15)

# Email Settings (Nodemailer - Example uses Ethereal for testing)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_SECURE=false # Use 'true' for 465, 'false' for 587
SMTP_USERNAME=your_ethereal_email_or_real_smtp_user
SMTP_PASSWORD=your_ethereal_password_or_real_smtp_pass
EMAIL_FROM=support@authsystem.com

# Frontend URL (for email links)
CLIENT_URL=http://localhost:3000

# Initial Admin User for Seeding (only used if DB is empty)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=AdminPassword123!
USER_EMAIL=user@example.com
USER_PASSWORD=UserPassword123!
```