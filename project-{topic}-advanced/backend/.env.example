```dotenv
# Application Configuration
NODE_ENV=development
PORT=5000
API_VERSION=v1
CORS_ORIGIN=http://localhost:3000

# Database Configuration (PostgreSQL)
DB_HOST=localhost # For Docker compose, use 'postgres'
DB_PORT=5432
DB_USER=performancepulse_user
DB_PASSWORD=performancepulse_password
DB_DATABASE=performancepulse_db
DB_SYNC=false # Do NOT use true in production! Use migrations.

# JWT Secret
JWT_SECRET=supersecretjwtkeythatshouldbeverylongandrandominproduction
JWT_EXPIRES_IN=1h

# Redis Cache Configuration
REDIS_HOST=localhost # For Docker compose, use 'redis'
REDIS_PORT=6379
CACHE_TTL_SECONDS=3600 # Cache time-to-live in seconds

# Logging Configuration
LOG_LEVEL=debug # debug, info, warn, error

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000 # 1 minute
RATE_LIMIT_MAX_REQUESTS=100 # Max 100 requests per window

# Monitoring Job Configuration
MONITOR_CHECK_INTERVAL_CRON=* * * * * # Every minute, standard cron format. For testing use a short interval.
```