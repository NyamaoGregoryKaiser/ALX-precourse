```
# Application Configuration
PORT=5000
NODE_ENV=development # development, production, test
FRONTEND_URL=http://localhost:3000

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here_please_change_this_in_production_!!!
JWT_ACCESS_EXPIRATION_MINUTES=30
JWT_REFRESH_EXPIRATION_DAYS=7

# Database Configuration (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=sqlinsight
DB_PASSWORD=sqlinsight
DB_NAME=sqlinsight_db
DB_SYNCHRONIZE=false # Set to true ONLY for development/testing, use migrations in production
DB_LOGGING=false # Set to true for detailed SQL query logging in development

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000 # 1 minute
RATE_LIMIT_MAX=100 # 100 requests per minute per IP
```

#### `docker-compose.yml`