NODE_ENV=development
PORT=5000

# Database Configuration (for development, use direct config.json values or override)
DB_USER=user
DB_PASSWORD=password
DB_NAME=task_management_db
DB_HOST=localhost
DB_PORT=5432
DB_DIALECT=postgres

# JWT Secret
JWT_SECRET=YOUR_VERY_STRONG_AND_LONG_SECRET_KEY
JWT_EXPIRES_IN=1h

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000

# Redis configuration (if using Redis for caching in production)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=