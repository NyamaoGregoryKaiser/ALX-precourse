{
  "name": "sql-insight-pro-backend",
  "version": "1.0.0",
  "description": "Backend for SQLInsight Pro database optimization system",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "nodemon --exec ts-node src/server.ts",
    "build": "tsc",
    "typeorm": "typeorm-ts-node-commonjs",
    "migrate:make": "npm run typeorm migration:create ./src/database/migrations/$npm_config_name",
    "migrate:run": "npm run typeorm migration:run -- -d ./src/config/database.ts",
    "migrate:revert": "npm run typeorm migration:revert -- -d ./src/config/database.ts",
    "seed:run": "ts-node ./src/database/seeds/index.ts",
    "test": "jest --detectOpenHandles --coverage --maxWorkers=50%",
    "test:watch": "jest --watch --maxWorkers=50%",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [],
  "author": "ALX Software Engineering Program",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.17.21",
    "pg": "^8.11.5",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.20",
    "winston": "^3.13.0",
    "yup": "^1.4.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
