```json
{
  "name": "task-management-backend",
  "version": "1.0.0",
  "description": "Backend API for a Collaborative Task Management System",
  "main": "dist/server.js",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "npx ts-node -r tsconfig-paths/register src/database/scripts/generate-typeorm-config.ts && tsc",
    "start": "node dist/server.js",
    "dev": "nodemon --exec \"ts-node -r tsconfig-paths/register\" src/server.ts",
    "typeorm": "typeorm-ts-node-commonjs -d src/database/config/typeorm.config.ts",
    "db:migrate": "npm run typeorm migration:run",
    "db:migrate:undo": "npm run typeorm migration:revert",
    "db:migrate:create": "npm run typeorm migration:create src/database/migrations/$NAME",
    "db:seed": "ts-node -r tsconfig-paths/register src/database/seeders/run-seeders.ts",
    "db:reset": "npm run typeorm schema:drop && npm run db:migrate && npm run db:seed",
    "test": "jest --runInBand --coverage --detectOpenHandles --forceExit",
    "test:watch": "jest --watch --runInBand",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix"
  },
  "keywords": [],
  "author": "ALX Software Engineer",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "joi": "^17.13.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.5",
    "reflect-metadata": "^0.2.2",
    "rimraf": "^5.0.7",
    "typeorm": "^0.3.20",
    "winston": "^3.13.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/joi": "^17.2.3",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.12",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^7.10.0",
    "@typescript-eslint/parser": "^7.10.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.5"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src",
      "<rootDir>/tests"
    ],
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/server.ts",
      "!src/app.ts",
      "!src/database/migrations/*.ts",
      "!src/database/seeders/*.ts",
      "!src/database/config/*.ts",
      "!src/config/*.ts",
      "!src/types/*.ts",
      "!src/**/*.dtos.ts",
      "!src/shared/validators/*.ts"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  }
}
