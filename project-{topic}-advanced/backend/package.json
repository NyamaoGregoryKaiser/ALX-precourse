    "seed": "ts-node src/data-source.ts seed",
    "test": "jest --detectOpenHandles --forceExit --coverage",
    "test:unit": "jest --detectOpenHandles --forceExit --coverage --testPathPattern=src/__tests__/unit",
    "test:integration": "jest --detectOpenHandles --forceExit --coverage --testPathPattern=src/__tests__/integration",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix"
