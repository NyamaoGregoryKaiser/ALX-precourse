{
  "name": "project-management-api",
  "version": "1.0.0",
  "description": "A comprehensive, production-ready API for project management.",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "NODE_ENV=development nodemon src/server.js",
    "test": "NODE_ENV=test jest --coverage --runInBand --forceExit --detectOpenHandles",
    "test:watch": "npm test -- --watch",
    "test:unit": "NODE_ENV=test jest --testPathPattern=src/tests/unit --coverage",
    "test:integration": "NODE_ENV=test jest --testPathPattern=src/tests/integration --coverage",
    "test:api": "NODE_ENV=test jest --testPathPattern=src/tests/api --coverage",
    "lint": "eslint \"src/**/*.js\"",
    "lint:fix": "eslint --fix \"src/**/*.js\"",
    "db:migrate": "sequelize db:migrate",
    "db:migrate:undo": "sequelize db:migrate:undo",
    "db:seed": "sequelize db:seed:all",
    "db:seed:undo": "sequelize db:seed:undo:all",
    "db:reset": "npm run db:migrate:undo && npm run db:migrate && npm run db:seed",
    "db:test:reset": "NODE_ENV=test sequelize db:migrate:undo:all && NODE_ENV=test sequelize db:migrate && NODE_ENV=test sequelize db:seed:all",
    "docker:up": "docker-compose up -d --build",
    "docker:down": "docker-compose down"
  },
  "keywords": [
    "node",
    "express",
    "sequelize",
    "postgresql",
    "jwt",
    "redis",
    "docker",
    "ci/cd",
    "testing",
    "api"
  ],
  "author": "ALX Software Engineering Team",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "http-status": "^1.7.4",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.30.1",
    "pg": "^8.12.0",
    "pg-hstore": "^2.3.4",
    "redis": "^4.6.15",
    "sequelize": "^6.37.3",
    "winston": "^3.13.0",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.5.0",
    "eslint": "^9.5.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.1",
    "globals": "^15.6.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "sequelize-cli": "^6.6.2",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFilesAfterEnv": [
      "<rootDir>/src/tests/setupTests.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/app.js",
      "!src/server.js",
      "!src/db/migrations/*.js",
      "!src/db/seeders/*.js",
      "!src/db/models/index.js",
      "!src/config/config.js",
      "!src/utils/catchAsync.js",
      "!src/utils/ApiError.js",
      "!src/middleware/error.middleware.js",
      "!src/routes/*.js",
      "!src/tests/**/*.js"
    ]
  }
}