```prisma
// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(uuid()) @map("user_id")
  username     String    @unique @db.VarChar(50)
  email        String    @unique @db.VarChar(100)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  messages     Message[]
  ownedChannels Channel[] @relation("OwnedChannels")
  channelUsers ChannelUser[]

  @@map("users")
}

model Channel {
  id          String    @id @default(uuid()) @map("channel_id")
  name        String    @unique @db.VarChar(100)
  description String?   @db.VarChar(255)
  ownerId     String    @map("owner_id")
  type        String    @default("PUBLIC") @db.VarChar(20) // e.g., "PUBLIC", "PRIVATE"
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  owner       User      @relation("OwnedChannels", fields: [ownerId], references: [id], onDelete: Cascade)
  messages    Message[]
  channelUsers ChannelUser[]

  @@map("channels")
}

model Message {
  id        String   @id @default(uuid()) @map("message_id")
  content   String   @db.Text
  userId    String   @map("user_id")
  channelId String   @map("channel_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([channelId, createdAt]) // Optimize message fetching for channels by date
  @@map("messages")
}

model ChannelUser {
  channelId String @map("channel_id")
  userId    String @map("user_id")
  joinedAt  DateTime @default(now()) @map("joined_at")

  channel   Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([channelId, userId]) // Composite primary key
  @@map("channel_users")
}
```

