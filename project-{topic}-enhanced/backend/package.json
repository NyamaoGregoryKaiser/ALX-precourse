{
  "name": "task-management-backend",
  "version": "1.0.0",
  "description": "Backend for a comprehensive Task Management System",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "concurrently \"npx tsc --watch\" \"nodemon -q dist/server.js\"",
    "build": "npx tsc",
    "typeorm": "typeorm-ts-node-commonjs",
    "migration:create": "npx typeorm-ts-node-commonjs migration:create ./src/migrations/$npm_config_name",
    "migration:generate": "npx typeorm-ts-node-commonjs migration:generate ./src/migrations/$npm_config_name -d src/config/data-source.ts",
    "migration:run": "npx typeorm-ts-node-commonjs migration:run -d src/config/data-source.ts",
    "migration:revert": "npx typeorm-ts-node-commonjs migration:revert -d src/config/data-source.ts",
    "seed": "ts-node -r tsconfig-paths/register src/seeds/run-seeds.ts",
    "test": "jest --detectOpenHandles --forceExit --coverage",
    "test:watch": "jest --watch --detectOpenHandles --forceExit",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "prettier": "prettier --write \"{src,apps,libs,test}/**/*.ts\""
  },
  "keywords": [],
  "author": "ALX Software Engineering Student",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.2",
    "cache-manager": "^5.2.4",
    "cache-manager-redis-yet": "^5.0.0",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "joi": "^17.12.3",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.5",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.20",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/body-parser": "^1.19.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/joi": "^17.2.3",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.7",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^7.6.0",
    "@typescript-eslint/parser": "^7.6.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "prettier": "^3.2.5",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.5"
  }
}