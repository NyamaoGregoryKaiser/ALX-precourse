```
# Application
NODE_ENV=development
PORT=5000
APP_NAME="PaymentProcessor"

# Database (PostgreSQL)
DB_CLIENT=pg
DB_HOST=localhost
DB_PORT=5432
DB_USER=paymentuser
DB_PASSWORD=paymentpassword
DB_NAME=payment_db

# JWT Authentication
JWT_SECRET=supersecretjwtkeythatshouldbeverylongandrandom
JWT_EXPIRATION_TIME=1d # 1 day

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Payment Gateway (Mock)
MOCK_GATEWAY_API_KEY=mock_api_key_123
MOCK_GATEWAY_URL=http://localhost:5001/mock-gateway # If you had a separate mock gateway service

# Webhooks
WEBHOOK_SECRET=webhook_signing_secret_for_validation

# Logging
LOG_LEVEL=info # debug, info, warn, error
```