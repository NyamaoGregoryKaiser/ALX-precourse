```
PORT=5000
NODE_ENV=development

DATABASE_URL="postgresql://user:password@localhost:5432/chat_db?schema=public"
# For Docker: DATABASE_URL="postgresql://user:password@db:5432/chat_db?schema=public"

JWT_SECRET=supersecretjwtkeythatshouldbechangedinproduction
JWT_ACCESS_EXPIRATION_MINUTES=30
JWT_REFRESH_EXPIRATION_DAYS=7

REDIS_HOST=localhost
REDIS_PORT=6379
# For Docker: REDIS_HOST=redis
# REDIS_PASSWORD=

LOG_LEVEL=info

CLIENT_ORIGIN=http://localhost:3000
# For Docker: CLIENT_ORIGIN=http://localhost:3000
```