NODE_ENV=development
PORT=5000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=admin
DB_PASSWORD=admin
DB_DATABASE=auth_db
DB_DATABASE_TEST=auth_test_db

# JWT Configuration
JWT_SECRET=supersecretjwtkey
JWT_REFRESH_SECRET=supersecretjwtrefreshkey
JWT_ACCESS_TOKEN_EXPIRATION=15m
JWT_REFRESH_TOKEN_EXPIRATION=7d

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# CORS Origins
CORS_ORIGIN=* # Or specify domains, e.g., http://localhost:3000

# Other
LOG_LEVEL=info
```
*Note: Create a `.env` file from `.env.example` and fill in actual values for production.*

##### **`server/tsconfig.json`**

```json