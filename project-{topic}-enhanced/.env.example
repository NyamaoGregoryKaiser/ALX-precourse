```
# Application Configuration
APP_PORT=18080
APP_ENV=development # development, production, test

# Database Configuration
DATABASE_PATH=./data/app.db

# JWT Configuration
JWT_SECRET_KEY=your_very_secret_jwt_key_that_is_at_least_32_chars_long
JWT_EXPIRATION_SECONDS=3600 # 1 hour

# Logging Configuration
LOG_LEVEL=info # trace, debug, info, warn, error, critical, off
LOG_FILE=./logs/app.log

# Cache Configuration
CACHE_TTL_SECONDS=300 # 5 minutes for cached items

# Rate Limiting Configuration (Fixed Window)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60 # 100 requests per minute per IP

# Admin User Setup (for initial seeding/testing)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=adminpassword123
```