```dotenv
# --- General ---
NODE_ENV=development # development, test, production
SERVER_PORT=5000
CLIENT_URL=http://localhost:3000

# --- Database (DBOptiFlow's own database) ---
DB_HOST=db-optiflow-postgres
DB_PORT=5432
DB_USER=dbopti_user
DB_PASSWORD=dbopti_password
DB_NAME=dbopti_db

# --- JWT Secret (change in production!) ---
JWT_ACCESS_SECRET=your_access_secret_key_change_this_in_production
JWT_REFRESH_SECRET=your_refresh_secret_key_change_this_in_production
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# --- Redis Cache ---
REDIS_HOST=db-optiflow-redis
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Monitoring Scheduler (simulated) ---
MONITORING_INTERVAL_MINUTES=5 # How often to simulate data generation

# --- Frontend environment variables (prefixed with VITE_) ---
VITE_API_BASE_URL=http://localhost:5000/api
```