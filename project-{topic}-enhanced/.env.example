```
# Application Settings
PROJECT_NAME="PaymentProcessor"
PROJECT_DESCRIPTION="A comprehensive payment processing system."
PROJECT_VERSION="1.0.0"
DEBUG=True
PORT=8000

# Database Settings (PostgreSQL)
# For local dev with Docker: postgresql+asyncpg://user:password@db:5432/dbname
DATABASE_URL="postgresql+asyncpg://admin:password@localhost:5432/payment_db"
TEST_DATABASE_URL="postgresql+asyncpg://admin:password@localhost:5433/test_payment_db"

# Security Settings
SECRET_KEY="your-super-secret-key-replace-this-in-production" # Generate a strong one: openssl rand -hex 32
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=10080 # 7 days

# Redis Settings (for Caching and Rate Limiting)
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD="" # Set a strong password in production
REDIS_DB=0
REDIS_CACHE_TTL_SECONDS=300

# External Payment Gateway (Simulated)
# If running mock gateway in docker-compose, use 'http://mock-gateway:8001/mock-gateway'
PAYMENT_GATEWAY_API_URL="http://localhost:8001/mock-gateway" 
PAYMENT_GATEWAY_API_KEY="your_gateway_secret_key"
PAYMENT_GATEWAY_WEBHOOK_SECRET="your_webhook_validation_secret"

# Webhook Delivery Settings
WEBHOOK_MAX_RETRIES=5
WEBHOOK_RETRY_DELAY_SECONDS=60

```