# Server Configuration
PORT=5000
NODE_ENV=development # or production

# Client Configuration
CLIENT_URL=http://localhost:3000

# Database Configuration (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=user
DB_PASSWORD=password
DB_DATABASE=task_db
DB_SYNC=false # Do NOT set to true in production. Use migrations instead.
DB_LOGGING=false # Set to true for debugging SQL queries

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here_change_me
JWT_EXPIRES_IN=1d

# Redis Configuration (for Caching/Rate Limiting)
REDIS_HOST=localhost
REDIS_PORT=6379

# Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=900000 # 15 minutes (15 * 60 * 1000)
RATE_LIMIT_MAX_REQUESTS=100 # Max 100 requests per window