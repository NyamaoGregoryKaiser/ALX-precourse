```
# FastAPI Application Settings
APP_NAME="Personal Finance Tracker API"
DEBUG=True
ENVIRONMENT="development" # development, testing, staging, production
SECRET_KEY="YOUR_SUPER_SECRET_KEY_GOES_HERE_MAKE_IT_VERY_LONG_AND_RANDOM"
ACCESS_TOKEN_EXPIRE_MINUTES=60 # Token expiration in minutes
REFRESH_TOKEN_EXPIRE_MINUTES=10080 # 7 days
ALGORITHM="HS256"

# Database Settings
POSTGRES_SERVER="db"
POSTGRES_USER="user"
POSTGRES_PASSWORD="password"
POSTGRES_DB="finances_db"
POSTGRES_PORT="5432"

# Redis Settings (for Caching and Rate Limiting)
REDIS_HOST="redis"
REDIS_PORT="6379"
REDIS_DB=0 # Database index for Redis

# Logging Configuration
LOG_LEVEL="INFO" # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FILE_PATH="./app_logs.log"
```