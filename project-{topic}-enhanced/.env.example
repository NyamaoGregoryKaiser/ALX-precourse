```
# Global Environment Variables for Docker Compose

# Backend (Node.js/Express)
NODE_ENV=development
PORT=5000
DATABASE_URL=postgres://user:password@db:5432/cms_db # 'db' is the service name in docker-compose
JWT_SECRET=your_jwt_secret_key_here # CHANGE THIS IN PRODUCTION
JWT_EXPIRES_IN=1h
SESSION_SECRET=your_session_secret_key_here # CHANGE THIS IN PRODUCTION
FRONTEND_URL=http://localhost:3000

# Redis (Caching and Sessions)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Frontend (React)
REACT_APP_API_BASE_URL=http://localhost:5000/api/v1
```