# Server Configuration
SERVER_PORT=8080
SERVER_HOST=0.0.0.0
STATIC_FILES_PATH=./web

# Database Configuration (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=dbo_user
DB_PASSWORD=dbo_password_secure
DB_NAME=database_optimizer_db
DB_CONNECTION_STRING="postgresql://dbo_user:dbo_password_secure@localhost:5432/database_optimizer_db"

# JWT Authentication
JWT_SECRET="a_very_long_and_secure_random_string_for_jwt_signing_which_is_at_least_32_characters_long"

# Logging Configuration
LOG_LEVEL=info # trace, debug, info, warn, error, critical, off
LOG_FILE=logs/app.log

# Application Specific
SLOW_QUERY_THRESHOLD_MS=50.0  # Queries slower than this are considered "slow"
MIN_INDEX_SUGGESTION_USAGE=5 # Minimum times a column is used in slow queries to suggest an index
```