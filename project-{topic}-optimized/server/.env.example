NODE_ENV=development
PORT=3000

# Database Configuration
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=mlutilshub_user
DB_PASSWORD=password
DB_NAME=mlutilshub_db

# JWT Configuration
JWT_SECRET=supersecretjwtkey_please_change_this_in_production!
JWT_EXPIRES_IN=1h

# Caching Configuration
CACHE_TTL=3600 # Time-To-Live in seconds for cached items (1 hour)

# Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=60000 # 1 minute
RATE_LIMIT_MAX_REQUESTS=100 # Max 100 requests per window

# File Uploads (Optional: for production, consider S3 or similar)
UPLOAD_DIR=./uploads
```