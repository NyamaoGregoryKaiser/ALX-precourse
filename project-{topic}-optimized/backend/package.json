{
  "name": "enterprise-api-backend",
  "version": "1.0.0",
  "description": "Enterprise-Grade API Backend with Node.js, Express, and PostgreSQL",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "cross-env NODE_ENV=development nodemon src/server.js",
    "test": "cross-env NODE_ENV=test jest --detectOpenHandles --verbose --coverage",
    "test:watch": "cross-env NODE_ENV=test jest --watch --detectOpenHandles",
    "migrate": "sequelize db:migrate",
    "migrate:create": "sequelize migration:generate --name",
    "migrate:undo": "sequelize db:migrate:undo",
    "seed": "sequelize db:seed:all",
    "seed:undo": "sequelize db:seed:undo:all",
    "lint": "eslint src/ --fix",
    "prettier": "prettier --write 'src/**/*.js'"
  },
  "keywords": [
    "node",
    "express",
    "api",
    "postgresql",
    "sequelize",
    "jwt",
    "caching",
    "rate-limiting",
    "docker",
    "alx"
  ],
  "author": "ALX Software Engineering Student",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "cross-env": "^7.0.3",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pg": "^8.11.3",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.35.2",
    "swagger-ui-express": "^5.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@eslint/js": "^8.56.0",
    "eslint": "^8.56.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-prettier": "^5.1.3",
    "globals": "^13.20.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.1",
    "sequelize-cli": "^6.6.2",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/frontend/"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/tests/setup.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/config/*.js",
      "!src/server.js",
      "!src/app.js",
      "!src/routes/*.js",
      "!src/middleware/logger.js",
      "!src/middleware/rateLimit.js",
      "!src/middleware/cache.js",
      "!src/utils/jwt.js",
      "!src/utils/errors.js",
      "!src/migrations/*.js",
      "!src/seeders/*.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 70,
        "lines": 70,
        "statements": 70
      }
    }
  }
}
