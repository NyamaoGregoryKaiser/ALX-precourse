```
NODE_ENV=development

# Application
API_PORT=3000
API_PREFIX=/api/v1
CLIENT_URL=http://localhost:3001 # Or specific domain for production

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=paymentuser
DB_PASSWORD=paymentpassword
DB_NAME=paymentdb

# JWT Secret & Expiry
JWT_SECRET=supersecretjwtkeythatshouldbeverylongandcomplexinproduction
JWT_EXPIRES_IN=1h

# Redis Cache
REDIS_HOST=localhost
REDIS_PORT=6379

# Logging
LOG_LEVEL=info # debug, info, warn, error
```