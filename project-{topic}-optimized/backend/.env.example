# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# Database Configuration
DATABASE_TYPE=postgres
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_USERNAME=admin
DATABASE_PASSWORD=password
DATABASE_NAME=task_management

# JWT Secret
JWT_SECRET=supersecretjwtkey
JWT_EXPIRATION_TIME=3600s # 1 hour

# Redis Cache
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_TTL=3600 # 1 hour in seconds

# Rate Limiting
THROTTLE_TTL=60 # 1 minute
THROTTLE_LIMIT=100 # 100 requests per minute