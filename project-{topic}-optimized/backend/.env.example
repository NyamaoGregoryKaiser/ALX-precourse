```
# Application
PORT=3000
NODE_ENV=development # or production, test

# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=cmsuser
DATABASE_PASSWORD=cmspassword
DATABASE_NAME=cmsdb

# JWT Authentication
JWT_SECRET=supersecretjwtkey # CHANGE THIS IN PRODUCTION
JWT_EXPIRATION_TIME=3600 # 1 hour

# Logging
LOG_LEVEL=info # debug, info, warn, error

# Rate Limiting
RATE_LIMIT_TTL=60 # seconds
RATE_LIMIT_MAX_REQUESTS=100 # requests per TTL
```