# Server Configuration
PORT=5000
NODE_ENV=development # development, test, production

# Database Configuration (PostgreSQL)
DB_DIALECT=postgres
DB_HOST=postgres
DB_PORT=5432
DB_USER=your_db_user # e.g., devuser
DB_PASSWORD=your_db_password # e.g., devpassword
DB_NAME=api_db # e.g., api_dev_db, api_test_db

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD= # Optional: if your Redis requires a password

# JWT Configuration
JWT_SECRET=supersecretjwtkey # CHANGE THIS IN PRODUCTION! Use a long, random string.
JWT_EXPIRES_IN=1h # e.g., 15m, 1h, 7d
REFRESH_TOKEN_SECRET=anothersupersecretrefreshkey # CHANGE THIS IN PRODUCTION!
REFRESH_TOKEN_EXPIRES_IN=7d

# Logging Configuration
LOG_LEVEL=debug # debug, info, warn, error

# Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=60000 # 1 minute
RATE_LIMIT_MAX_REQUESTS=100 # Max requests per window

# CORS Origin (for frontend access)
CORS_ORIGIN=http://localhost:3000
```