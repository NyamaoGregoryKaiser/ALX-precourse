// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
  MANAGER # Can manage projects/teams
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  BLOCKED
}

model User {
  id        String    @id @default(uuid())
  username  String    @unique
  email     String    @unique
  password  String    @map("password_hash") // Store hashed passwords
  firstName String?
  lastName  String?
  role      Role      @default(USER)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  teams     TeamMember[] // Link to TeamMember join table
  projects  Project[]    @relation("UserProjects") // User can own multiple projects
  tasks     Task[]       @relation("AssigneeTasks") // User can be assigned multiple tasks
  comments  Comment[]    @relation("CommentAuthor") // User can author multiple comments

  @@map("users") // Map model to 'users' table
}

model Team {
  id        String       @id @default(uuid())
  name      String       @unique
  description String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  members   TeamMember[] // Link to TeamMember join table
  projects  Project[]    // Team can have multiple projects

  @@map("teams")
}

// Join table for User and Team (Many-to-Many)
model TeamMember {
  id        String    @id @default(uuid())
  userId    String
  teamId    String
  role      Role      @default(USER) // Role within the team (e.g., Team Lead, Member)
  assignedAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId]) // A user can only be a member of a team once
  @@map("team_members")
}

model Project {
  id          String    @id @default(uuid())
  name        String
  description String?
  startDate   DateTime?
  endDate     DateTime?
  status      String    @default("active") // e.g., active, completed, on-hold
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  ownerId     String? // User who created/owns the project
  owner       User?     @relation("UserProjects", fields: [ownerId], references: [id], onDelete: SetNull)

  teamId      String? // Optional: Project can belong to a team
  team        Team?     @relation(fields: [teamId], references: [id], onDelete: SetNull)

  tasks       Task[]    // Project can have multiple tasks

  @@map("projects")
}

model Task {
  id          String       @id @default(uuid())
  title       String
  description String?
  status      TaskStatus   @default(TODO)
  priority    Int          @default(1) // e.g., 1 (low) to 5 (critical)
  dueDate     DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  projectId   String
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  assigneeId  String? // User assigned to the task
  assignee    User?        @relation("AssigneeTasks", fields: [assigneeId], references: [id], onDelete: SetNull)

  comments    Comment[]    // Task can have multiple comments
  attachments Attachment[] // Task can have multiple attachments

  @@map("tasks")
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  authorId  String
  author    User     @relation("CommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@map("comments")
}

model Attachment {
  id        String   @id @default(uuid())
  filename  String
  fileUrl   String // URL or path to the stored file
  fileType  String?
  fileSize  Int?     // Size in bytes
  uploadedAt DateTime @default(now())

  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("attachments")
}
