{
  "name": "mobile-backend-system",
  "version": "1.0.0",
  "description": "A comprehensive, production-ready mobile app backend system.",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --detectOpenHandles --forceExit",
    "test:coverage": "jest --coverage --detectOpenHandles --forceExit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prisma:generate": "npx prisma generate",
    "prisma:migrate:dev": "npx prisma migrate dev",
    "prisma:migrate:deploy": "npx prisma migrate deploy",
    "prisma:seed": "ts-node prisma/seed.ts",
    "db:reset": "npx prisma migrate reset --force --skip-generate --skip-seed && npm run prisma:seed",
    "db:push": "npx prisma db push --skip-generate",
    "docs": "swagger-ui-express -f ./docs/swagger.yaml -s ./docs/swagger.yaml"
  },
  "keywords": [
    "nodejs",
    "express",
    "prisma",
    "postgresql",
    "mobile-backend",
    "production-ready",
    "jwt",
    "redis",
    "docker",
    "ci/cd",
    "testing"
  ],
  "author": "ALX Software Engineer",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.5.2",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.1",
    "helmet": "^7.0.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "redis": "^4.6.10",
    "swagger-ui-express": "^5.0.0",
    "winston": "^3.11.0",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.5",
    "@types/compression": "^1.7.4",
    "@types/cors": "^2.8.15",
    "@types/express": "^4.17.20",
    "@types/jest": "^29.5.7",
    "@types/jsonwebtoken": "^9.0.3",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.8.10",
    "@types/supertest": "^2.0.16",
    "@types/swagger-ui-express": "^4.1.4",
    "@types/yamljs": "^0.2.33",
    "eslint": "^8.52.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.1",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "prettier": "^3.0.3",
    "prisma": "^5.5.2",
    "supertest": "^6.3.3",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2"
  }
}