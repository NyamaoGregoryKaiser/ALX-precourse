{
  "name": "payment-processing-system",
  "version": "1.0.0",
  "description": "A comprehensive, production-ready payment processing system.",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "NODE_ENV=development nodemon src/server.js",
    "test": "NODE_ENV=test jest --detectOpenHandles --forceExit --verbose",
    "test:unit": "NODE_ENV=test jest tests/unit --detectOpenHandles --forceExit",
    "test:integration": "NODE_ENV=test jest tests/integration --detectOpenHandles --forceExit",
    "test:api": "NODE_ENV=test jest tests/api --detectOpenHandles --forceExit",
    "coverage": "NODE_ENV=test jest --coverage --detectOpenHandles --forceExit",
    "db:migrate": "knex --knexfile src/db/knexfile.js migrate:latest",
    "db:rollback": "knex --knexfile src/db/knexfile.js migrate:rollback",
    "db:seed": "knex --knexfile src/db/knexfile.js seed:run",
    "db:reset": "npm run db:rollback && npm run db:migrate && npm run db:seed"
  },
  "keywords": [
    "payment-gateway",
    "nodejs",
    "express",
    "postgresql",
    "redis",
    "jwt",
    "docker",
    "api"
  ],
  "author": "ALX Software Engineering Student",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.2",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "joi": "^17.13.1",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "pg": "^8.11.5",
    "redis": "^4.6.14",
    "swagger-ui-express": "^5.0.0",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/tests/"
    ]
  }
}