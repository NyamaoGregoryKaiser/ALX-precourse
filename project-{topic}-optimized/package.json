{
  "name": "mobile-backend-system",
  "version": "1.0.0",
  "description": "A comprehensive, production-ready mobile app backend system.",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --detectOpenHandles --coverage --testTimeout=10000",
    "test:unit": "jest --detectOpenHandles --coverage src/tests/unit",
    "test:integration": "jest --detectOpenHandles --coverage src/tests/integration",
    "test:api": "jest --detectOpenHandles --coverage src/tests/api",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "prettier": "prettier --check \"src/**/*.js\"",
    "prettier:fix": "prettier --write \"src/**/*.js\"",
    "db:migrate": "prisma migrate dev --name init",
    "db:seed": "node seed.js",
    "db:reset": "prisma migrate reset --force --skip-seed",
    "db:studio": "prisma studio",
    "prisma:generate": "prisma generate"
  },
  "keywords": [
    "nodejs",
    "express",
    "prisma",
    "postgresql",
    "redis",
    "jwt",
    "docker",
    "backend",
    "mobile",
    "api",
    "task-management"
  ],
  "author": "ALX Software Engineering",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^5.16.1",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "redis": "^4.6.15",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "prettier": "^3.3.2",
    "prisma": "^5.16.1",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFilesAfterEnv": [
      "./src/tests/setup.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/app.js",
      "!src/server.js",
      "!src/config/**",
      "!src/routes/**",
      "!src/tests/**"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  }
}