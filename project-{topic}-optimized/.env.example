# FastAPI Application Settings
PROJECT_NAME="Mobile Task Manager API"
API_V1_STR="/api/v1"
LOG_LEVEL="INFO" # DEBUG, INFO, WARNING, ERROR, CRITICAL

# Database Settings
POSTGRES_SERVER=db
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=taskmanagerdb
# DATABASE_URL="postgresql+asyncpg://user:password@db/taskmanagerdb" # Uncomment to hardcode

# JWT Secret Key - IMPORTANT: Change this to a strong, random string in production!
SECRET_KEY="YOUR_SUPER_SECRET_KEY_HERE"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=10080 # 7 days (60 * 24 * 7)

# Redis Settings
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
# REDIS_URL="redis://redis:6379/0" # Uncomment to hardcode
```