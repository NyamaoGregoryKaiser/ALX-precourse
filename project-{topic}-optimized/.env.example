# FastAPI Application Settings
PROJECT_NAME="Performance Monitoring System"
PROJECT_DESCRIPTION="An enterprise-grade system for monitoring application performance."
API_VERSION="0.1.0"
API_V1_STR="/api/v1"

# Security
SECRET_KEY="your_secret_key_for_jwt_replace_me_in_prod"
ACCESS_TOKEN_EXPIRE_MINUTES=10080 # 7 days

# Database Settings
POSTGRES_SERVER=db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=perf_monitor_db
POSTGRES_PORT=5432

# Redis Settings (for Caching and Rate Limiting)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# CORS Configuration (comma-separated list of origins)
# Example: BACKEND_CORS_ORIGINS="http://localhost:3000,https://yourfrontend.com"
BACKEND_CORS_ORIGINS="http://localhost:8080,http://127.0.0.1:8080" # Add your frontend URL(s)

# Uvicorn Server Settings
UVICORN_HOST=0.0.0.0
UVICORN_PORT=8000

# Initial Admin User Credentials (for database seeding)
FIRST_SUPERUSER_EMAIL="admin@example.com"
FIRST_SUPERUSER_PASSWORD="adminpass"

# Logging Level (INFO, DEBUG, WARNING, ERROR, CRITICAL)
LOG_LEVEL="INFO"

# Background Task Intervals
DATA_COLLECTION_INTERVAL_SECONDS=30 # Simulate new metric data every 30 seconds
ALERT_EVALUATION_INTERVAL_SECONDS=60 # Check alert rules every 60 seconds
```

#### `Dockerfile`
```dockerfile