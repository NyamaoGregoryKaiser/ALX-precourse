```
# Application Environment
APP_ENV=development # production, development, test

# Database Configuration
# Using SQLite for local development; for production, use PostgreSQL/MySQL
DB_CONNECTION=sqlite3
DB_PATH=./db/app.db

# JWT Secret for authentication
# Generate a strong, random key in production: e.g., 'openssl rand -base64 32'
JWT_SECRET=YOUR_SUPER_SECRET_JWT_KEY_HERE_CHANGE_ME_IN_PRODUCTION
```