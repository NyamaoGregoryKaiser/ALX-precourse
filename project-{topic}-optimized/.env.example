# FastAPI Application Settings
APP_NAME="Mobile Backend"
APP_VERSION="1.0.0"
DEBUG=True
SECRET_KEY="YOUR_SUPER_SECRET_KEY_HERE_CHANGE_ME_IN_PRODUCTION"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080 # 7 days
ALGORITHM="HS256"

# Database Settings (PostgreSQL)
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin
POSTGRES_DB=mobile_db
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL="postgresql+asyncpg://admin:admin@db:5432/mobile_db"
TEST_DATABASE_URL="postgresql+asyncpg://admin:admin@localhost:5432/test_mobile_db" # For local testing without docker-compose

# Redis Settings
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
CACHE_EXPIRE_SECONDS=300 # Default cache expiry for @cache decorators

# Logging Settings
LOG_LEVEL=INFO
LOG_FORMAT='{"level": "%(levelname)s", "time": "%(asctime)s", "message": "%(message)s", "module": "%(name)s"}'

# Rate Limiting Settings
RATE_LIMIT_DEFAULT="10/minute" # Default rate limit for endpoints without specific configuration

# Environment
ENVIRONMENT=development
```