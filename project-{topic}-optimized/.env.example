NODE_ENV=development
PORT=3000

# JWT Configuration
JWT_SECRET=supersecretjwtkeythatshouldbeverylongandrandom
JWT_EXPIRES_IN=90d
JWT_COOKIE_EXPIRES_IN=90

# Database Configuration (Development)
DB_HOST=localhost
DB_PORT=5432
DB_USER=user
DB_PASSWORD=password
DB_NAME=payment_processor_dev

# Database Configuration (Test)
TEST_DB_HOST=localhost
TEST_DB_PORT=5432
TEST_DB_USER=testuser
TEST_DB_PASSWORD=testpassword
TEST_DB_NAME=payment_processor_test

# Database Configuration (Production - example for Heroku/Render, adjust as needed)
# PROD_DB_HOST=your_prod_db_host
# PROD_DB_PORT=5432
# PROD_DB_USER=your_prod_db_user
# PROD_DB_PASSWORD=your_prod_db_password
# PROD_DB_NAME=your_prod_db_name

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Cache
CACHE_TTL=300 # seconds

# Webhook Secret (for signing outgoing webhooks)
WEBHOOK_SIGNING_SECRET=anotherlongandrandomsecretforwebhooks