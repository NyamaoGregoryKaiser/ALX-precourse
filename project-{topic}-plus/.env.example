```
# FastAPI Application Settings
PROJECT_NAME="Mobile App Backend"
API_VERSION="1.0.0"
API_V1_STR="/api/v1"
DEBUG=True # Set to False for production

# Database Settings
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=app_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

# JWT Authentication Settings
SECRET_KEY="super-secret-key-for-development-only-please-change-in-production-!!!!!!"
ACCESS_TOKEN_EXPIRE_MINUTES=30 # Access token validity in minutes

# Logging Settings
LOG_LEVEL=INFO # DEBUG, INFO, WARNING, ERROR, CRITICAL

# Redis Settings for Caching and Rate Limiting
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Rate Limiting Settings (default for global middleware, can be overridden per endpoint)
DEFAULT_RATE_LIMIT="5/minute" # e.g., "5/minute", "100/hour", "10/second"
```