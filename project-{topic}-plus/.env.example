# FastAPI Application Settings
PROJECT_NAME="ML-Utilities-System"
SECRET_KEY="YOUR_SUPER_SECRET_KEY_HERE_MIN_32_CHARS" # Change this to a strong, random key in production!
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=300 # 5 hours

# PostgreSQL Database Settings
POSTGRES_SERVER=db
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=ml_utils_db
POSTGRES_PORT=5432
# DATABASE_URL is automatically constructed from the above,
# but can be set explicitly if needed:
# DATABASE_URL="postgresql+asyncpg://user:password@db:5432/ml_utils_db"

# Redis Cache Settings
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Superuser Initial Credentials (for bootstrapping)
FIRST_SUPERUSER_EMAIL=admin@example.com
FIRST_SUPERUSER_PASSWORD=adminpassword

# CORS Origins (comma-separated list of allowed origins)
# Example: http://localhost:3000,https://your.frontend.com
BACKEND_CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"] # Leave empty for "*" in development, specify for production

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
```

#### `Dockerfile`
```dockerfile