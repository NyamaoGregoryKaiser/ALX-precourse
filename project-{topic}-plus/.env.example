FLASK_APP=manage.py
FLASK_ENV=development

# Core App Secrets
SECRET_KEY="your-backend-secret-key-here-strong-random-string"
JWT_SECRET_KEY="your-jwt-secret-key-here-strong-random-string"

# Database Configuration (for Docker Compose setup)
DATABASE_URL="postgresql://user:password@db:5432/dataviz_db"
DEV_DATABASE_URL="postgresql://user:password@localhost:5432/dataviz_dev"
TEST_DATABASE_URL="postgresql://user:password@localhost:5432/dataviz_test"

# JWT Expiration
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRES_DAYS=7

# Redis Configuration (for Docker Compose setup)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0 # For caching
RATELIMIT_STORAGE_URL="redis://redis:6379/1" # For rate limiting, use a different DB

# Logging Configuration
LOG_LEVEL=INFO # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FILE=app.log
LOG_MAX_BYTES=10485760 # 10 MB
LOG_BACKUP_COUNT=5

# Data Source Limits
MAX_UPLOAD_SIZE_MB=50