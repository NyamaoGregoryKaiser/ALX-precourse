```ini
# .env file for ALX-Shop API configuration

# --- Project Settings ---
PROJECT_NAME="ALX-Shop API"
ENVIRONMENT="development" # Options: development, testing, production

# --- Database Configuration ---
# PostgreSQL connection string for the main application database
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_USER=alxuser
DATABASE_PASSWORD=alxpassword
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=alxshop_db

# Asynchronous database URL (used by the FastAPI app)
ASYNC_DATABASE_URL="postgresql+asyncpg://${DATABASE_USER}:${DATABASE_PASSWORD}@${DATABASE_HOST}:${DATABASE_PORT}/${DATABASE_NAME}"

# Synchronous database URL (used by Alembic, can be same as ASYNC_DATABASE_URL or specific sync driver like psycopg2)
# For Alembic, it's often simpler to use a synchronous driver if you don't need async in env.py itself.
# We configured alembic/env.py to use async engine directly, so this can be the same or specific.
# Setting it here for completeness, though ASYNC_DATABASE_URL is primarily used by our app.
# If your alembic setup expects a sync URL, uncomment and adjust:
# DATABASE_URL="postgresql+psycopg2://${DATABASE_USER}:${DATABASE_PASSWORD}@${DATABASE_HOST}:${DATABASE_PORT}/${DATABASE_NAME}"
# For consistency, if you're using ASYNC_DATABASE_URL directly, Alembic also uses it in our setup.
# Let's ensure DATABASE_URL is also set for `pydantic-settings` even if ASYNC_DATABASE_URL is preferred.
DATABASE_URL="${ASYNC_DATABASE_URL}" # Use the async URL for both by default in settings.

# --- Test Database Configuration (Optional, for testing environment) ---
# Use a separate database for running tests to prevent data corruption.
# This will override DATABASE_URL and ASYNC_DATABASE_URL in testing mode if set.
TEST_DATABASE_NAME=alxshop_test_db
TEST_DATABASE_URL="postgresql+asyncpg://${DATABASE_USER}:${DATABASE_PASSWORD}@${DATABASE_HOST}:${DATABASE_PORT}/${TEST_DATABASE_NAME}"

# --- JWT Authentication ---
# A strong, long, random string. Generate with `openssl rand -hex 32` or similar.
SECRET_KEY="your-super-secret-key-replace-this-in-production"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM="HS256"

# --- CORS Settings ---
# Comma-separated list of allowed origins (e.g., http://localhost:3000,https://yourfrontend.com)
# Set to "*" for development to allow all origins.
BACKEND_CORS_ORIGINS=["http://localhost:3000", "http://127.0.0.1:3000"] # Example for local frontend

# --- Redis Configuration (for Caching and Rate Limiting) ---
REDIS_URI="redis://localhost:6379/0" # Default Redis URI

# --- Logging Configuration ---
LOG_LEVEL="INFO" # Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# --- Default Admin User (for seeding) ---
DEFAULT_ADMIN_EMAIL="admin@alx.com"
DEFAULT_ADMIN_PASSWORD="adminpassword"
DEFAULT_ADMIN_FULL_NAME="ALX Admin"
```