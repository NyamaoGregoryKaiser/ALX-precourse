# Environment variables for the C++ API Server
# Copy this to a .env file and fill in actual values for local development.
# In Docker, these are often passed via docker-compose.yml or Dockerfile ARG/ENV.

# Application Port
APP_PORT=9080

# Database Configuration
DATABASE_PATH=./data/database.db

# JWT Secret Key (MUST be strong and kept secret)
JWT_SECRET=super_secret_jwt_key_please_change_this_in_production_environment_to_a_random_long_string

# JWT Expiration Time (in seconds, e.g., 1 hour = 3600)
JWT_EXPIRATION_SECONDS=3600

# Rate Limiting Configuration
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=100

# Admin User Seed (for initial setup)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin_password

# Log Level (DEBUG, INFO, WARN, ERROR)
LOG_LEVEL=DEBUG
```