```dotenv
# Application Environment
NODE_ENV=development # development, production, test
PORT=3000

# Database Configuration (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/taskdb?schema=public"

# JWT Configuration
JWT_SECRET=supersecretkey123!
JWT_EXPIRES_IN=7d
JWT_COOKIE_EXPIRES_IN=7 # Days

# Redis Configuration for Caching and Session Store
REDIS_URL=redis://localhost:6379
REDIS_CACHE_TTL_SECONDS=3600 # Cache Time-To-Live in seconds (1 hour)

# Admin User Seed Data (for initial setup)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=adminpassword123
```