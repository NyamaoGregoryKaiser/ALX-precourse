```ini
# --- Flask Application Configuration ---
FLASK_APP=run.py
FLASK_CONFIG=development # development, testing, production
SECRET_KEY=your_flask_secret_key_here_change_in_prod
JWT_SECRET_KEY=your_jwt_secret_key_here_change_in_prod

# --- Database Configuration (PostgreSQL) ---
# Development Database (used by Flask app and Alembic for 'development' config)
DEV_DATABASE_URL=postgresql://dev_user:dev_password@localhost:5432/performance_monitor_dev
# Testing Database (used by Flask app for 'testing' config)
TEST_DATABASE_URL=postgresql://test_user:test_password@localhost:5433/performance_monitor_test
# Production Database (used by Flask app for 'production' config, adjust 'db' to your actual DB host)
DATABASE_URL=postgresql://user:password@db:5432/performance_monitor_prod

# --- Redis Configuration (for Caching and Rate Limiting) ---
REDIS_HOST=localhost # 'redis' if running in Docker network
REDIS_PORT=6379
REDIS_DB=0 # Database index for Redis

# --- Monitoring Configuration ---
DEFAULT_POLLING_INTERVAL_SECONDS=60 # Default interval for new endpoints if not specified
```