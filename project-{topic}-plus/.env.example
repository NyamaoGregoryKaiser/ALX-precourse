# Application
NODE_ENV=development
PORT=5000
BACKEND_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000

# Database (PostgreSQL)
DB_HOST=db
DB_PORT=5432
DB_USER=scrapeflow_user
DB_PASSWORD=scrapeflow_password
DB_NAME=scrapeflow_db

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_key_please_change_this_in_production
JWT_EXPIRATION_TIME=1h

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000 # 1 minute
RATE_LIMIT_MAX_REQUESTS=100 # 100 requests per window

# Scraping Worker (BullMQ)
BULLMQ_QUEUE_NAME=scrapeflow-jobs
BULLMQ_WORKER_CONCURRENCY=5 # Number of concurrent scraping jobs