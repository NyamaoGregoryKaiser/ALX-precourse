# Core Application Settings
APP_NAME="Project Management API"
APP_VERSION="1.0.0"
ENVIRONMENT="development" # Options: development, testing, production
DEBUG=True

# Database Settings
DATABASE_URL="postgresql://user:password@localhost:5432/project_db"
TEST_DATABASE_URL="postgresql://user:password@localhost:5433/test_project_db" # Use a different port/db for tests!

# JWT Settings
SECRET_KEY="YOUR_SUPER_SECRET_KEY_REPLACE_THIS_IN_PRODUCTION" # Use `openssl rand -hex 32` to generate a strong key
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=1440

# Logging Settings
LOG_LEVEL="INFO" # Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FILE_PATH="app.log"
LOG_RETENTION_DAYS=7
LOG_ROTATION_SIZE_MB=10

# Rate Limiting Settings
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_DB=0
RATE_LIMIT_DEFAULT="100/minute" # Example: 100 requests per minute

# CORS Settings - Comma separated list of origins
BACKEND_CORS_ORIGINS="http://localhost:8000,http://localhost:5173"
```