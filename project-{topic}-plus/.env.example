# .env.example - Environment variables for local development

# Application Configuration
APP_PORT=8080
APP_NAME="CppDevOpsSystem"
APP_ENV="development" # development, production, test

# JWT Configuration
JWT_SECRET_KEY="supersecretkey123!@#" # CHANGE THIS FOR PRODUCTION
JWT_EXPIRATION_SECONDS=3600 # 1 hour

# Database Configuration
# For SQLite, specify path. Will be mounted from db/app.db via Docker Compose.
DATABASE_PATH="/app/data/app.db"
# For external databases, you might use a connection string like:
# DATABASE_URL="postgresql://user:password@host:port/dbname"

# Logging Configuration
LOG_LEVEL="info" # trace, debug, info, warn, error, critical
LOG_FILE_PATH="/app/logs/app.log"
LOG_MAX_SIZE_MB=10 # Max size of log file before rotation
LOG_MAX_FILES=5 # Max number of rotated log files

# Caching Configuration
CACHE_TTL_SECONDS=300 # 5 minutes

# Rate Limiting Configuration
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=100 # Max requests per window
RATE_LIMIT_WINDOW_SECONDS=60 # Window in seconds (e.g., 60s for 1 minute)

# Test Database Configuration (for integration tests)
TEST_DATABASE_PATH="/app/data/test_app.db"