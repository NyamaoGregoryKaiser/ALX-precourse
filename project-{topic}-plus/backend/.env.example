```ini
# Database Connection
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=task_manager_user
DATABASE_PASSWORD=your_secure_password
DATABASE_NAME=task_manager_db

# JWT Configuration
JWT_SECRET=supersecretjwtkeythatshouldbemorethan32charslongandrandom
# Recommended: Generate a strong, random key. e.g., using `openssl rand -base64 32`

# Server Configuration
SERVER_PORT=8080

# For testing (if needed, e.g., separate test database)
# TEST_DATABASE_NAME=task_manager_test_db
```