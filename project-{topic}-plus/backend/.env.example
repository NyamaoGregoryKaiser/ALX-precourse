```env
PORT=5000
DATABASE_URL="postgresql://user:password@localhost:5432/realtime_chat_db?schema=public"
JWT_SECRET="your_very_strong_and_secret_jwt_key_here"
REDIS_URL="redis://localhost:6379"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000 # 1 minute
RATE_LIMIT_MAX_REQUESTS=100 # 100 requests per IP per window
```