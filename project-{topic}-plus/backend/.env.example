# Application Configuration
NODE_ENV=development
PORT=5000
LOG_LEVEL=info # debug, info, warn, error

# Database Configuration (PostgreSQL)
# For local setup, replace user, password, host, port with your PostgreSQL credentials
# For Docker, host will be 'db' (the service name in docker-compose.yml)
DATABASE_URL="postgresql://user:password@localhost:5432/pms_db?schema=public"
TEST_DATABASE_URL="postgresql://user:password@localhost:5433/pms_test_db?schema=public" # Separate DB for tests

# JWT Configuration
JWT_SECRET=YOUR_VERY_STRONG_JWT_SECRET_KEY_HERE # min 32 characters, generate randomly, e.g., openssl rand -base64 32
JWT_EXPIRES_IN=1h

# Hashing Configuration
SALT_ROUNDS=10 # Number of salt rounds for bcrypt, usually 10-12

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000 # 1 minute
RATE_LIMIT_MAX_REQUESTS=100 # Max 100 requests per window for authenticated users
RATE_LIMIT_GUEST_MAX_REQUESTS=20 # Max 20 requests per window for guests

# Caching
CACHE_TTL_SECONDS=300 # 5 minutes default time to live for cached items