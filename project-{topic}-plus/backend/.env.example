```
# FastAPI Application Settings
APP_NAME="Real-Time Chat App"
APP_VERSION="1.0.0"
DEBUG=True

# Database Settings (PostgreSQL)
POSTGRES_SERVER="db"
POSTGRES_USER="chatuser"
POSTGRES_PASSWORD="chatpassword"
POSTGRES_DB="chatdb"
DATABASE_URL="postgresql+asyncpg://chatuser:chatpassword@db:5432/chatdb" # Used by backend

# Redis Settings
REDIS_HOST="redis"
REDIS_PORT=6379
REDIS_URL="redis://redis:6379/0" # Used by backend

# JWT Settings
SECRET_KEY="supersecretkey-DO-NOT-USE-IN-PRODUCTION-CHANGE-ME"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30 # 30 minutes

# Frontend Configuration (for Docker Compose, if different from backend URLs)
FRONTEND_BACKEND_URL="http://localhost:8000"
FRONTEND_WEBSOCKET_URL="ws://localhost:8000/ws"

# Logging Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO
```