{
  "name": "scrapeflow-backend",
  "version": "1.0.0",
  "description": "Backend for ScrapeFlow web scraping tool",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "nodemon --exec ts-node src/server.ts",
    "build": "rimraf dist && tsc",
    "test": "jest --detectOpenHandles --forceExit --coverage",
    "test:watch": "jest --watch --detectOpenHandles",
    "typeorm": "typeorm-ts-node-commonjs",
    "typeorm:migration:create": "npm run typeorm migration:create ./src/db/migrations/%npm_config_name%",
    "typeorm:migration:run": "npm run typeorm migration:run -d ./src/db/data-source.ts",
    "typeorm:migration:revert": "npm run typeorm migration:revert -d ./src/db/data-source.ts",
    "typeorm:seed": "ts-node src/db/seeders/index.ts"
  },
  "keywords": [],
  "author": "ALX Software Engineering",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.10.0",
    "cheerio": "^1.0.0-rc.12",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.12.0",
    "reflect-metadata": "^0.2.2",
    "redis": "^4.6.15",
    "typeorm": "^0.3.20",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cheerio": "^0.22.35",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-rate-limit": "^6.0.0",
    "@types/jest": "^29.5.12",
    "@types/joi": "^17.2.3",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.9",
    "@types/supertest": "^6.0.2",
    "@types/winston": "^2.4.4",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "rimraf": "^6.0.1",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.3"
  }
}