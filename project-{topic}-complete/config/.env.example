```ini
# Example .env file for ML-Toolkit Server
# This file should NOT be committed to version control in production environments.
# Use these environment variables to override values in config/default.conf.

# Database Credentials (REQUIRED for production)
ML_DB_HOST=my.production.database.com
ML_DB_PORT=5432
ML_DB_NAME=ml_toolkit_prod_db
ML_DB_USER=prod_ml_user
ML_DB_PASSWORD=YOUR_STRONG_DATABASE_PASSWORD_HERE

# API Port
ML_API_PORT=80

# JWT Secret (CRITICAL for production)
ML_JWT_SECRET=REALLY_LONG_AND_COMPLEX_SECRET_KEY_FOR_JWT_SIGNING

# Log Level (Optional)
# ML_LOG_LEVEL=debug
```