```ini
# Core Application Settings
PROJECT_NAME="DataVizSystem"
PROJECT_VERSION="1.0.0"
API_V1_STR="/api/v1"

# Database Configuration (PostgreSQL)
POSTGRES_SERVER="localhost" # Or the Docker service name 'db'
POSTGRES_USER="admin"
POSTGRES_PASSWORD="password"
POSTGRES_DB="dataviz_db"
POSTGRES_PORT=5432
# DATABASE_URL="postgresql+asyncpg://admin:password@localhost:5432/dataviz_db" # If uncommented, this overrides individual components

# JWT Secret Key (MUST be a long, random string in production)
SECRET_KEY="your-super-secret-key-that-is-at-least-32-characters-long-and-randomized"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=10080 # 7 days

# Admin User Credentials (for initial seeding)
FIRST_SUPERUSER_EMAIL="admin@example.com"
FIRST_SUPERUSER_PASSWORD="adminpassword"

# CORS Origins (Frontend URL)
BACKEND_CORS_ORIGINS=["http://localhost:3000"] # Add production frontend URL here too

# Redis Configuration (for Caching and Rate Limiting)
REDIS_HOST="localhost" # Or the Docker service name 'redis'
REDIS_PORT=6379
REDIS_DB=0
# REDIS_URL="redis://localhost:6379/0" # If uncommented, this overrides individual components

# Environment
ENVIRONMENT="development" # development, testing, production
```