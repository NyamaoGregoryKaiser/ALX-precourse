```
# .env.example

# Flask Application Settings
FLASK_APP=manage.py
FLASK_ENV=development
SECRET_KEY='your_super_secret_key_here_for_flask_sessions_and_jwt'
DEBUG=True

# Database Settings (for DPA's own database)
DATABASE_URL=postgresql://dpa_user:dpa_password@dpa_db:5432/dpa_db

# Redis Settings
REDIS_HOST=dpa_redis
REDIS_PORT=6379
REDIS_DB=0
CACHE_REDIS_URL=redis://dpa_redis:6379/0

# Celery Settings
CELERY_BROKER_URL=redis://dpa_redis:6379/1
CELERY_RESULT_BACKEND=redis://dpa_redis:6379/2

# JWT Settings
JWT_SECRET_KEY='your_jwt_secret_key_here_for_token_signing'
JWT_ACCESS_TOKEN_EXPIRES_DAYS=7

# Admin User for Seeding
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=adminpass

# Sample User for Seeding
SAMPLE_USERNAME=testuser
SAMPLE_EMAIL=test@example.com
SAMPLE_PASSWORD=testpass

# Log Level
LOG_LEVEL=INFO

# Rate Limiting
RATE_LIMIT_DEFAULT="200 per day; 50 per hour"
RATE_LIMIT_AUTH="5 per minute"
```