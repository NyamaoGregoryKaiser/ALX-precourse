*   **Caching Layer (`app/utils/Cache.hpp`):** A simple in-memory LRU cache with TTL.
    *   **`Cache.hpp`**
        ```cpp
        #ifndef CACHE_HPP
        #define CACHE_HPP

        #include <string>
        #include <unordered_map>
        #include <list>
        #include <chrono>
        #include <mutex>
        #include "Poco/JSON/Object.h"
        #include "Poco/SharedPtr.h"
        #include "Poco/Timestamp.h"
        #include "utils/Logger.hpp"

        template <typename Key, typename Value>
        class Cache {
        private:
            struct CacheEntry {
                Value value;
                Poco::Timestamp expiryTime;
            };

            std::unordered_map<Key, typename std::list<std::pair<Key, CacheEntry>>::iterator> _cacheMap;
            std::list<std::pair<Key, CacheEntry>> _cacheList; // Stores (Key, CacheEntry) for LRU
            size_t _maxSize;
            long _ttlSeconds; // Time to live for cache entries in seconds
            std::mutex _mutex;

            Cache() : _maxSize(1000), _ttlSeconds(300) {} // Default values
            Cache(const Cache&) = delete;
            Cache& operator=(const Cache&) = delete;

        public:
            static Cache& instance() {
                static Cache instance;
                return instance;
            }

            static void initialize(size_t maxSize, long ttlSeconds) {
                std::lock_guard<std::mutex> lock(instance()._mutex);
                instance()._maxSize = maxSize;
                instance()._ttlSeconds = ttlSeconds;
                DB_OPTIMIZER_LOG_INFO("Cache initialized with max_size={} and TTL={}s", maxSize, ttlSeconds);
            }

            void put(const Key& key, const Value& value) {
                std::lock_guard<std::mutex> lock(_mutex);
                Poco::Timestamp now;
                CacheEntry entry = {value, now + Poco::Timespan(_ttlSeconds, 0)};

                auto it = _cacheMap.find(key);
                if (it != _cacheMap.end()) {
                    _cacheList.erase(it->second);
                    _cacheMap.erase(it);
                }

                _cacheList.emplace_front(key, entry);
                _cacheMap[key] = _cacheList.begin();

                if (_cacheList.size() > _maxSize) {
                    _cacheMap.erase(_cacheList.back().first);
                    _cacheList.pop_back();
                }
                // DB_OPTIMIZER_LOG_DEBUG("Cache put: {}", key);
            }

            Value get(const Key& key) {
                std::lock_guard<std::mutex> lock(_mutex);
                auto it = _cacheMap.find(key);
                if (it == _cacheMap.end()) {
                    return Value(); // Or throw, or return std::optional
                }

                // Check expiry
                Poco::Timestamp now;
                if (it->second->second.expiryTime < now) {
                    _cacheList.erase(it->second);
                    _cacheMap.erase(it);
                    // DB_OPTIMIZER_LOG_DEBUG("Cache expired: {}", key);
                    return Value();
                }

                // Move to front (LRU)
                _cacheList.splice(_cacheList.begin(), _cacheList, it->second);
                // DB_OPTIMIZER_LOG_DEBUG("Cache hit: {}", key);
                return _cacheList.begin()->second.value;
            }

            bool contains(const Key& key) {
                std::lock_guard<std::mutex> lock(_mutex);
                auto it = _cacheMap.find(key);
                if (it == _cacheMap.end()) {
                    return false;
                }
                Poco::Timestamp now;
                if (it->second->second.expiryTime < now) {
                    _cacheList.erase(it->second);
                    _cacheMap.erase(it);
                    return false;
                }
                return true;
            }

            size_t size() const {
                std::lock_guard<std::mutex> lock(_mutex);
                return _cacheList.size();
            }

            void clear() {
                std::lock_guard<std::mutex> lock(_mutex);
                _cacheMap.clear();
                _cacheList.clear();
                DB_OPTIMIZER_LOG_INFO("Cache cleared.");
            }
        };

        #endif // CACHE_HPP
        ```
    *   Usage: `Cache<std::string, Poco::JSON::Object::Ptr>::instance().put("user:1", userJsonObj);`
*   **Rate Limiting (`app/utils/RateLimiter.hpp`):** A simple token bucket implementation.
    *   **`RateLimiter.hpp`**
        ```cpp
        #ifndef RATE_LIMITER_HPP
        #define RATE_LIMITER_HPP

        #include <mutex>
        #include <chrono>
        #include "Poco/Timestamp.h"
        #include "utils/Logger.hpp"

        class RateLimiter {
        private:
            std::mutex _mutex;
            double _tokens;
            double _capacity; // Max tokens
            double _refillRatePerSecond; // Tokens added per second
            Poco::Timestamp _lastRefillTime;

            RateLimiter() : _tokens(0.0), _capacity(100.0), _refillRatePerSecond(5.0) {
                _lastRefillTime.update();
            }
            RateLimiter(const RateLimiter&) = delete;
            RateLimiter& operator=(const RateLimiter&) = delete;

            void refill() {
                Poco::Timestamp now;
                Poco::Timespan elapsed = now - _lastRefillTime;
                double tokensToAdd = elapsed.totalMicroseconds() / 1000000.0 * _refillRatePerSecond;
                _tokens = std::min(_capacity, _tokens + tokensToAdd);
                _lastRefillTime = now;
            }

        public:
            static RateLimiter& instance() {
                static RateLimiter instance;
                return instance;
            }

            static void initialize(double capacity, double refillRatePerSecond) {
                std::lock_guard<std::mutex> lock(instance()._mutex);
                instance()._capacity = capacity;
                instance()._refillRatePerSecond = refillRatePerSecond;
                instance()._tokens = capacity; // Start with full bucket
                instance()._lastRefillTime.update();
                DB_OPTIMIZER_LOG_INFO("RateLimiter initialized with capacity={} and refill_rate={} tokens/s", capacity, refillRatePerSecond);
            }

            bool tryAcquire(double tokensToConsume = 1.0) {
                std::lock_guard<std::mutex> lock(_mutex);
                refill();
                if (_tokens >= tokensToConsume) {
                    _tokens -= tokensToConsume;
                    return true;
                }
                return false;
            }

            double getTokens() {
                std::lock_guard<std::mutex> lock(_mutex);
                refill();
                return _tokens;
            }
        };

        #endif // RATE_LIMITER_HPP
        ```
    *   Usage (e.g., in `RequestHandler` or a dedicated `RateLimitMiddleware`):
        ```cpp
        if (!RateLimiter::instance().tryAcquire()) {
            // Return 429 Too Many Requests
        }
        ```

